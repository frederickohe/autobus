# ================================
# Blotato Configuration
# ================================
# Get your credentials from https://app.blotato.com/settings/api

# API Key for server-to-server authentication
BLOTATO_API_KEY=your_blotato_api_key_here

# OAuth Credentials for user authentication
BLOTATO_CLIENT_ID=your_blotato_client_id_here
BLOTATO_CLIENT_SECRET=your_blotato_client_secret_here

# Where Blotato will redirect after user authorizes
BLOTATO_REDIRECT_URI=https://your-production-domain.com/api/social/callback

# For development/testing
# BLOTATO_REDIRECT_URI=http://localhost:8000/api/social/callback

# Blotato API endpoints (usually don't change these)
BLOTATO_API_BASE_URL=https://app.blotato.com
BLOTATO_OAUTH_URL=https://app.blotato.com/oauth/authorize

# ================================
# Security Notes
# ================================
# 1. Never commit actual credentials to git
# 2. Use strong, unique tokens
# 3. Rotate tokens regularly
# 4. Encrypt tokens in production database
# 5. Use HTTPS for all Blotato integrations
# 6. Enable CORS only for your frontend domain in production
